# Flask Configuration
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=True

# Application
SECRET_KEY=replace_with_a_secure_random_secret_key

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=shop_billing_db

# SQLAlchemy (Optional)
# Uncomment if using Flask-SQLAlchemy
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:your_mysql_password@localhost:3306/shop_billing_db
# SQLALCHEMY_TRACK_MODIFICATIONS=False

# Session Configuration
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=3600

# Mail Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=[your_email@gmail.com](mailto:your_email@gmail.com)
MAIL_PASSWORD=your_email_app_password

# File Upload Configuration
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Logging
LOG_LEVEL=INFO

# Application Information
APP_NAME=Shop Billing System
APP_VERSION=1.0.0

# Production
# FLASK_ENV=production
# FLASK_DEBUG=False
